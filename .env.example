FLASK_ENV=development
FLASK_DEBUG=1
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text
MAX_CONTENT_LENGTH_MB=2
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=180

RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CHROMA_DIR=chromadb_store
# Embedding backend: "hashing" (no dependencies), "ollama" (recommended), or "sentence-transformers"
EMBEDDING_BACKEND=ollama
# Model for Ollama embedding backend (requires: ollama pull nomic-embed-text)
OLLAMA_EMBED_MODEL=nomic-embed-text
# Optional if you later install sentence-transformers and want higher-quality semantic search.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local Ollama defaults.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1
SFIM_MAX_REFINEMENT_ROUNDS=1
SFIM_MIN_CONFIDENCE=0.70
SFIM_SELF_EVAL_MEMORY_PATH=data/processed/self_eval_memory.jsonl

# Optional OpenAI fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
